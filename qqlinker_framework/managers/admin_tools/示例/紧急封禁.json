{
  "name": "紧急封禁",
  "description": "立即封禁指定玩家并踢出游戏，同时向QQ群发送通知",
  "require_confirm": true,
  "min_tier": "daemon",
  "fail_strategy": "continue_on_error",
  "steps": [
    {
      "description": "在游戏内警告该玩家",
      "module": "adapter",
      "method": "send_game_command",
      "args": {"command": "say §c[警告] §f违规操作，即将被封禁"}
    },
    {
      "description": "封禁指定玩家（Orion系统）",
      "module": "orion",
      "method": "ban_player",
      "args_from_ctx": true,
      "timeout": 10
    },
    {
      "description": "踢出该玩家",
      "module": "orion",
      "method": "kick_player",
      "args_from_ctx": true
    },
    {
      "description": "向管理QQ群发送封禁通知",
      "module": "message",
      "method": "send_to_admin_group",
      "args": {"msg": "🚨 已执行紧急封禁操作，详见Orion面板"}
    }
  ]
}

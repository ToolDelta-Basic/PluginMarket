[flake8]
max-line-length = 88
extend-ignore =
    # 行过长（DEI 项目中有大量中文注释，82 字符限制不合理）
    E501,
    # 缩进对齐（代码风格偏好，不影响功能）
    E122, E127, E128, E131,
    # 空格风格
    E203, E221, E231, E261,
    # 空行风格
    E301, E302, E303, E305, E306,
    # import 风格
    E401, E402,
    # 单行多语句
    E701, E702,
    # lambda 赋值
    E731,
    # 模糊变量名
    E741,
    # 尾随空格
    W291, W293,
    # 无效转义
    W605,
    # 未使用的 import（模块导入有注册副作用，不能随意删除）
    F401,
    # 条件表达式中的 pass
    W292
per-file-ignores =
    testing/*:F401
    __init__.py:F401
